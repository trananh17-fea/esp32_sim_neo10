VITE_TRACKER_API_BASE=https://gps-tracker.ahcntab.workers.dev

# Preferred: Google Apps Script webhook that writes leads to Google Sheet.
VITE_GOOGLE_SHEET_WEBHOOK_URL=

# Fallback when no webhook is configured. Vite dev/preview saves to data/leads.jsonl.
VITE_LOCAL_LEAD_ENDPOINT=/api/leads

# You can use an embed URL, or put a local file in public/videos and use:
# VITE_DEMO_VIDEO_EMBED_URL=videos/basew-demo.mp4
VITE_DEMO_VIDEO_EMBED_URL=videos/basew-demo.mp4

# Landing opens this URL when users click the web tracking demo button.
# Local default assumes web-tracking is running on port 3000.
VITE_TRACKING_WEB_URL=http://localhost:3000/
VITE_LEAD_FORM_DEMO_MODE=false

# Optional analytics
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
